{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TVBox",
  "version": "0.1.0",
  "identifier": "com.tvbox.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "TVBox 影视仓",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
